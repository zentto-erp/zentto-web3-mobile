{
  "name": "zentto-web3-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Zentto Web3 — app móvil de usuarios (neobanco cripto). Ionic React + Capacitor.",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3200 --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 3200",
    "lint": "eslint src --ext .ts,.tsx",
    "cap:sync": "cap sync",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/cli": "^6.2.0",
    "@capacitor/clipboard": "^6.0.3",
    "@capacitor/core": "^6.2.0",
    "@capacitor/haptics": "^6.0.2",
    "@capacitor/ios": "^6.2.0",
    "@capacitor/keyboard": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/share": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.2",
    "@ionic/react": "^8.4.0",
    "@ionic/react-router": "^8.4.0",
    "@tanstack/react-query": "^5.62.0",
    "capacitor-native-biometric": "^4.2.2",
    "capacitor-secure-storage-plugin": "^0.10.0",
    "ionicons": "^7.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
